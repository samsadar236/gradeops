# Copy to .env and fill in.

# --- LLM provider --------------------------------------------------------
# 'google'    : Gemini via langchain-google-genai (FREE tier — recommended)
# 'anthropic' : Claude via langchain-anthropic   (paid)
LLM_PROVIDER=google

# --- Google Gemini (free) ------------------------------------------------
# Get a key at: https://aistudio.google.com/app/apikey
# No billing required.
GOOGLE_API_KEY=

# gemini-2.5-flash-lite has the highest free-tier quota of any vision-
# capable Gemini (15 RPM / 1000 RPD). Switch to gemini-2.5-flash or
# gemini-1.5-flash if you prefer their output quality and accept tighter
# rate limits.
GRADER_MODEL_GOOGLE=gemini-2.5-flash-lite

# --- Anthropic Claude (paid; only used if LLM_PROVIDER=anthropic) --------
ANTHROPIC_API_KEY=
GRADER_MODEL_ANTHROPIC=claude-sonnet-4-20250514

# --- Database ------------------------------------------------------------
DATABASE_URL=sqlite:///./gradeops.db
#   DATABASE_URL=postgresql+psycopg2://gradeops:gradeops@localhost:5432/gradeops

# --- OCR routing ---------------------------------------------------------
# 'hosted' uses whatever LLM_PROVIDER above (works without GPU).
# 'qwen_vl' uses Qwen2-VL via HuggingFace transformers (needs GPU).
OCR_BACKEND=hosted

# --- Storage -------------------------------------------------------------
STORAGE_ROOT=./storage

# --- Grader behavior -----------------------------------------------------
# Number of independent grading passes per answer. 1 = free-tier friendly,
# 5 = the full multi-pass design with median/max/std-dev aggregation.
GRADER_NUM_PASSES=1
# Critic retry limit. 0 disables the retry edge.
GRADER_CRITIC_RETRY=0

# --- Rate-limit throttling -----------------------------------------------
# Seconds between LLM calls. 4.5 keeps us under Gemini's free-tier 15 RPM.
# Set to 0 on paid tiers to disable throttling.
LLM_MIN_GAP_SECONDS=4.5

# --- Plagiarism ----------------------------------------------------------
PLAGIARISM_THRESHOLD=0.82
EMBEDDING_MODEL=sentence-transformers/all-MiniLM-L6-v2
